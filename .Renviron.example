# Example environment file. Copy to `.Renviron` (git-ignored) and fill in the
# credential for the provider set in config.yml. R reads `.Renviron` on startup.
#
# These are OPTIONAL: the app also supports bring-your-own-key (BYOK) - a user can
# paste an Anthropic / Google (Gemini) / OpenAI key in the "AI provider (your key)"
# card on the Review tab, held only in that browser session. A key set here is the
# server-side fallback used when no session key is entered. The deterministic
# ranking needs no key at all.

# --- Google Gemini API (API key - default provider) -------------------------
# ellmer chat_google_gemini() (Gemini Developer API). API-key path: key only - no
# project id, no location, no service-account file. Get a key at
# https://aistudio.google.com/apikey . GOOGLE_API_KEY works as an alias.
# This is where ANY Gemini API KEY goes, including a key created inside a Google
# Cloud project: usage then bills to that project (and its credits). Vertex AI
# (below) is a DIFFERENT thing - its endpoint rejects API keys and needs OAuth.
GEMINI_API_KEY=

# --- Anthropic (direct API) -------------------------------------------------
# Only if you set provider: anthropic in config.yml (Claude models).
ANTHROPIC_API_KEY=

# --- OpenAI (direct API) ----------------------------------------------------
# Only if you set provider: openai in config.yml (GPT models).
OPENAI_API_KEY=

# --- Google Vertex AI (only for provider: google_vertex) --------------------
# Vertex uses Application Default Credentials, NOT an API key: authenticate with
# `gcloud auth application-default login` (no file needed) OR a service-account JSON
# (GOOGLE_APPLICATION_CREDENTIALS), plus a project + region. Fill only for provider:
# google_vertex. Either naming works: VERTEX_* (ellmer's convention) is read first,
# then GOOGLE_CLOUD_* as an alias.
# VERTEX_PROJECT_ID=
# VERTEX_LOCATION=us-central1
#   (aliases: GOOGLE_CLOUD_PROJECT / GOOGLE_CLOUD_LOCATION)
# Only if using a service-account key file instead of `gcloud auth ... login`:
# GOOGLE_APPLICATION_CREDENTIALS=secrets/vertex-service-account.json
